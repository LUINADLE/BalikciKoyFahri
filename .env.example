# Balıkçıköy Fahri — Ortam Değişkenleri (örnek/şablon)
#
# Bu dosya COMMIT'LENİR ve yalnızca anahtar İSİMLERİNİ gösterir; gerçek değer içermez.
# Gerçek değerleri `.env.local` (lokal, gitignore'lu) ve Cloudflare paneline
# (Workers & Pages → balikcikoyfahri → Settings → Variables) gir.
#
# ── KURAL ────────────────────────────────────────────────────────────────────
# VITE_ önekli olanlar tarayıcıya gömülür → PUBLIC'tir. Yalnızca public anahtarlar
# VITE_ olabilir. service_role ve Resend anahtarları GİZLİDİR; VITE_ YAPMA, sadece
# Cloudflare ortam değişkeni (Secret) olarak — sunucu tarafı rezervasyon ucu için —
# tanımla. (Uç henüz atıl; bkz. docs/PHASE2_SETUP.md.)

# ── Frontend (public — VITE_) ────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Sunucu tarafı (GİZLİ — Cloudflare Pages'te Secret; VITE_ DEĞİL) ───────────
# Cloudflare Pages Function functions/api/reserve.js bunları kullanır.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Rezervasyon bildirimlerinin gönderileceği restoran adresi:
RESERVATION_TO_EMAIL=
# Resend'de doğrulanmış gönderen (ör. "Balıkçıköy Fahri <rezervasyon@alanadiniz.com>"):
RESERVATION_FROM_EMAIL=
